generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ CORE MODELS ============

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ops") // admin, ops, finance, volunteer
  avatar    String?
  phone     String?
  isActive  Boolean  @default(true)
  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs       AuditLog[]
  notifications   Notification[]
  createdCases    Case[]          @relation("CaseCreator")
  assignedCases   Case[]          @relation("CaseAssignee")
  deviceBindings  DeviceBinding[]
  securityLogs    SecurityLog[]
  securitySettings SecuritySettings?
}

// ============ MEMBER / ASNAF ============

model Member {
  id             String   @id @default(cuid())
  memberNumber   String   @unique // auto-generated: PUSPA-XXXX
  name           String
  ic             String   @unique
  phone          String
  email          String?
  address        String
  city           String?
  state          String?
  postalCode     String?
  householdSize  Int      @default(1)
  monthlyIncome  Float    @default(0)
  maritalStatus  String   @default("single") // single, married, divorced, widowed
  occupation     String?
  bankAccount    String?
  bankName       String?
  status         String   @default("active") // active, inactive, blacklisted
  notes          String?
  isDeleted      Boolean  @default(false)
  joinedAt       DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  cases            Case[]
  householdMembers HouseholdMember[]
  disbursements    Disbursement[]
  eKYCVerification EKYCVerification?

  @@index([memberNumber])
  @@index([ic])
  @@index([status])
}

model HouseholdMember {
  id           String  @id @default(cuid())
  name         String
  relationship String  // spouse, child, parent, sibling, other
  age          Int?
  occupation   String?
  income       Float   @default(0)
  isOKU        Boolean @default(false)
  isStudent    Boolean @default(false)
  memberId     String
  member       Member  @relation(fields: [memberId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ============ PROGRAMME ============

model Programme {
  id                  String    @id @default(cuid())
  name                String
  description         String?
  category            String    // food_aid, education, skills_training, healthcare, financial_assistance, community, emergency_relief, dawah
  status              String    @default("active") // active, completed, suspended, planned
  startDate           DateTime?
  endDate             DateTime?
  location            String?
  targetBeneficiaries Int?
  actualBeneficiaries Int       @default(0)
  budget              Float     @default(0)
  totalSpent          Float     @default(0)
  partners            String?
  notes               String?
  isDeleted           Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  cases                Case[]
  donations            Donation[]
  disbursements        Disbursement[]
  activities           Activity[]
  impactMetrics        ImpactMetric[]
  volunteerDeployments VolunteerDeployment[]
}

// ============ CASE WORKFLOW ============

model Case {
  id          String   @id @default(cuid())
  caseNumber  String   @unique // auto-generated: CS-XXXX
  title       String
  description String?
  status      String   @default("draft") // draft, submitted, verifying, verified, scoring, scored, approved, disbursing, disbursed, follow_up, closed, rejected
  priority    String   @default("normal") // urgent, high, normal, low
  category    String   @default("zakat") // zakat, sedekah, wakaf, infak, government_aid
  amount      Float    @default(0)

  // Linked member
  memberId       String?
  member         Member?   @relation(fields: [memberId], references: [id])

  programmeId    String?
  programme      Programme? @relation(fields: [programmeId], references: [id])

  creatorId      String
  creator        User      @relation("CaseCreator", fields: [creatorId], references: [id])
  assigneeId     String?
  assignee       User?     @relation("CaseAssignee", fields: [assigneeId], references: [id])

  verificationScore Float?  @default(0)
  welfareScore      Float?  @default(0)
  notes             String?
  isDeleted         Boolean @default(false)
  closedAt          DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  caseNotes     CaseNote[]
  caseDocuments CaseDocument[]
  disbursements Disbursement[]

  @@index([caseNumber])
  @@index([status])
  @@index([memberId])
}

model CaseNote {
  id        String   @id @default(cuid())
  content   String
  type      String   @default("note") // note, call, visit, assessment
  caseId    String
  case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CaseDocument {
  id         String   @id @default(cuid())
  name       String
  type       String   @default("document") // ic, income_proof, medical, photo, other
  url        String
  caseId     String
  case       Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
  uploadedBy String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ============ DONATION WITH ISF ============

model Donation {
  id             String   @id @default(cuid())
  donationNumber String   @unique // auto: DN-XXXX
  donorName      String
  donorIC        String?
  donorEmail     String?
  donorPhone     String?
  amount         Float
  status         String   @default("pending") // pending, confirmed, failed, refunded
  method         String   @default("cash") // cash, bank_transfer, online, cheque, ewallet
  channel        String?

  // ISF Segregation
  fundType       String   @default("donation_general") // zakat, sadaqah, waqf, infaq, donation_general
  zakatCategory  String?  // fitrah, harta, pendapatan, perniagaan (if fundType=zakat)
  zakatAuthority String?  // LZNK, MAIPS, MAIK, etc.
  shariahCompliant Boolean @default(true)

  isAnonymous     Boolean  @default(false)
  isTaxDeductible Boolean  @default(false)
  receiptNumber   String?
  isDeleted       Boolean  @default(false)

  programmeId String?
  programme   Programme? @relation(fields: [programmeId], references: [id])
  caseId      String?
  notes       String?
  donatedAt   DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([fundType])
  @@index([status])
}

// ============ DISBURSEMENT ============

model Disbursement {
  id                 String   @id @default(cuid())
  disbursementNumber String   @unique // auto: DB-XXXX
  amount             Float
  purpose            String
  status             String   @default("pending") // pending, approved, processing, completed, failed, cancelled
  recipientName      String
  recipientIC        String?
  recipientBank      String?
  recipientAcc       String?
  scheduledDate      DateTime?
  processedDate      DateTime?
  receiptUrl         String?
  notes              String?
  approvedBy         String?
  isDeleted          Boolean  @default(false)
  caseId             String?
  case               Case?    @relation(fields: [caseId], references: [id])
  programmeId        String?
  programme          Programme? @relation(fields: [programmeId], references: [id])
  memberId           String?
  member             Member?  @relation(fields: [memberId], references: [id])
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status])
}

// ============ ACTIVITY / KANBAN ============

model Activity {
  id          String    @id @default(cuid())
  title       String
  description String?
  type        String    @default("task") // task, event, meeting, fieldwork
  status      String    @default("planned") // planned, in_progress, completed, cancelled
  date        DateTime?
  endDate     DateTime?
  location    String?
  programmeId String?
  programme   Programme? @relation(fields: [programmeId], references: [id])
  assignees   String?   // JSON array of names
  notes       String?
  isDeleted   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  order       Int       @default(0)
}

// ============ COMPLIANCE ============

model OrganizationProfile {
  id                 String    @id @default(cuid())
  legalName          String
  tradeName          String?
  registrationType   String    @default("pertubuhan") // pertubuhan, syarikat, yayasan
  registrationNumber String?
  foundedDate        DateTime?
  registeredAddress  String?
  operatingAddress   String?
  phone              String?
  email              String?
  website            String?
  bankName           String?
  bankAccount        String?
  bankVerified       Boolean   @default(false)
  lhdnApprovalRef    String?
  lhdnApprovalExpiry DateTime?
  isTaxExempt        Boolean   @default(false)
  rosCertificateUrl  String?
  constitutionUrl    String?
  logoUrl            String?
  missionStatement   String?
  visionStatement    String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model BoardMember {
  id              String    @id @default(cuid())
  name            String
  title           String?
  role            String    // chairman, deputy_chairman, treasurer, secretary, deputy_secretary, adviser, committee
  appointmentDate DateTime?
  endDate         DateTime?
  phone           String?
  email           String?
  photo           String?
  bio             String?
  isCurrent       Boolean   @default(true)
  isDeleted       Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model Partner {
  id               String   @id @default(cuid())
  name             String
  type             String   @default("ngo") // corporate, foundation, government, ngo, masjid, individual
  relationship     String?
  contactPerson    String?
  contactPhone     String?
  contactEmail     String?
  address          String?
  verifiedStatus   String   @default("claimed") // claimed, partner_confirmed, publicly_verified
  verificationUrl  String?
  notes            String?
  isDeleted        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model ImpactMetric {
  id                 String    @id @default(cuid())
  programmeId        String
  programme          Programme @relation(fields: [programmeId], references: [id], onDelete: Cascade)
  metricName         String
  description        String?
  selfReportedValue  Float?
  verifiedValue      Float?
  verificationSource String?
  verificationDate   DateTime?
  verificationUrl    String?
  methodology        String?
  period             String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model PublicReport {
  id          String    @id @default(cuid())
  title       String
  type        String    // annual, financial, impact, audit
  year        String
  period      String?
  url         String?
  status      String    @default("draft") // draft, published, archived
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ComplianceChecklist {
  id          String   @id @default(cuid())
  category    String   // registration, governance, financial, programme, transparency
  item        String
  description String?
  isCompleted Boolean  @default(false)
  completedAt DateTime?
  evidenceUrl String?
  notes       String?
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ AUDIT LOG ============

model AuditLog {
  id        String   @id @default(cuid())
  action    String   // create, update, delete, login, logout, export, etc.
  entity    String   // Member, Case, Donation, etc.
  entityId  String?
  details   String?  // JSON
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  ipAddress String?
  createdAt DateTime @default(now())
}

// ============ NOTIFICATION ============

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info") // info, warning, error, success
  isRead    Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  link      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ CAPTURE ============

model Capture {
  id        String   @id @default(cuid())
  type      String   // text, voice, photo, link
  content   String
  metadata  String?  // JSON
  userId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ eKYC ============

model EKYCVerification {
  id             String   @id @default(cuid())
  memberId       String   @unique
  member         Member   @relation(fields: [memberId], references: [id])

  icFrontUrl     String?
  icBackUrl      String?
  icName         String?
  icNumber       String?
  icAddress      String?
  icDateOfBirth  DateTime?
  icGender       String?

  selfieUrl      String?
  livenessScore  Float?
  livenessMethod String?
  faceMatchScore Float?

  status         String   @default("pending") // pending, processing, verified, rejected, expired
  verifiedBy     String?
  verifiedAt     DateTime?
  rejectionReason String?

  bnmCompliant      Boolean  @default(false)
  amlaScreening     String?  // pass, fail, pending, review
  riskLevel         String?  // low, medium, high
  screeningNotes    String?

  walletEnabled       Boolean  @default(false)
  walletLimit         Float    @default(200)
  previousLimit       Float    @default(200)
  limitUpgradedAt     DateTime?
  bankTransferEnabled Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ TAPSECURE ============

model SecuritySettings {
  id                    String   @id @default(cuid())
  userId                String   @unique
  user                  User     @relation(fields: [userId], references: [id])

  biometricTransactions Boolean  @default(false)
  boundDeviceOnly       Boolean  @default(false)
  sessionTimeout        Int      @default(30) // minutes

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model DeviceBinding {
  id                String   @id @default(cuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id])

  deviceName        String?
  deviceType        String?  // mobile, desktop, tablet
  deviceFingerprint String?
  userAgent         String?
  ipAddress         String?
  location          String?

  isPrimary         Boolean  @default(false)
  isTrusted         Boolean  @default(false)
  isActive          Boolean  @default(true)
  otpVerified       Boolean  @default(false)

  lastUsedAt DateTime  @default(now())
  boundAt    DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model SecurityLog {
  id                String   @id @default(cuid())
  userId            String?
  user              User?    @relation(fields: [userId], references: [id])

  action            String   // login, device_bind, device_unbind, biometric_setup, transaction_verify, otp_sent, otp_verified, etc.
  method            String?  // password, webauthn, device_bind, face, fingerprint, otp
  deviceFingerprint String?
  ipAddress         String?
  userAgent         String?
  status            String   @default("success") // success, failed, blocked
  details           String?  // JSON

  createdAt DateTime @default(now())
}

// ============ VOLUNTEER MANAGEMENT ============

model Volunteer {
  id              String   @id @default(cuid())
  volunteerNumber String   @unique // auto: VOL-XXXX
  name            String
  ic              String   @unique
  phone           String
  email           String?
  address         String?
  city            String?
  state           String?
  occupation      String?
  skills          String?  // JSON array
  availability    String?  // weekday, weekend, anytime
  emergencyContact String?
  emergencyPhone  String?
  status          String   @default("active") // active, inactive, blacklisted
  isDeleted       Boolean  @default(false)
  joinedAt        DateTime @default(now())
  totalHours      Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  deployments  VolunteerDeployment[]
  hourLogs     VolunteerHourLog[]
  certificates VolunteerCertificate[]

  @@index([status])
  @@index([volunteerNumber])
}

model VolunteerDeployment {
  id          String    @id @default(cuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  programmeId String?
  programme   Programme? @relation(fields: [programmeId], references: [id])
  activityId  String?
  role        String    @default("participant") // coordinator, participant, lead
  status      String    @default("assigned") // assigned, confirmed, completed, cancelled
  startDate   DateTime
  endDate     DateTime?
  location    String?
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([volunteerId])
  @@index([status])
}

model VolunteerHourLog {
  id          String   @id @default(cuid())
  volunteerId String
  volunteer   Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  deploymentId String?
  date        DateTime
  hours       Float
  activity    String?
  approvedBy  String?
  approvedAt  DateTime?
  status      String   @default("pending") // pending, approved, rejected
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([volunteerId])
  @@index([status])
}

model VolunteerCertificate {
  id                String   @id @default(cuid())
  volunteerId       String
  volunteer         Volunteer @relation(fields: [volunteerId], references: [id], onDelete: Cascade)
  certificateNumber String   @unique // auto: CERT-XXXX
  title             String
  description       String?
  issuedAt          DateTime @default(now())
  totalHours        Float    @default(0)
  issuedBy          String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============ DONOR CRM ============

model Donor {
  id              String   @id @default(cuid())
  donorNumber     String   @unique // auto: DNR-XXXX
  name            String
  ic              String?
  phone           String?
  email           String?
  address         String?
  city            String?
  state           String?
  segment         String   @default("occasional") // major, regular, occasional, lapsed
  preferredContact String? // email, phone, whatsapp
  isAnonymous     Boolean  @default(false)
  notes           String?
  totalDonated    Float    @default(0)
  donationCount   Int      @default(0)
  firstDonationAt DateTime?
  lastDonationAt  DateTime?
  status          String   @default("active") // active, inactive
  isDeleted       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  communications DonorCommunication[]
  taxReceipts    TaxReceipt[]

  @@index([segment])
  @@index([status])
}

model DonorCommunication {
  id        String   @id @default(cuid())
  donorId   String
  donor     Donor    @relation(fields: [donorId], references: [id], onDelete: Cascade)
  type      String   // email, phone, whatsapp, letter
  subject   String
  content   String?
  status    String   @default("sent") // draft, sent, failed
  sentAt    DateTime?
  sentBy    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([donorId])
}

model TaxReceipt {
  id            String   @id @default(cuid())
  receiptNumber String   @unique // auto: TR-YYYY-XXXX
  donorId       String
  donor         Donor    @relation(fields: [donorId], references: [id])
  donationId    String?
  amount        Float
  donationDate  DateTime
  purpose       String   @default("Sumbangan amal kepada PUSPA")
  lhdnRef       String?
  issuedAt      DateTime @default(now())
  issuedBy      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([donorId])
  @@index([receiptNumber])
}

// ============ DOCUMENT MANAGEMENT ============

model Document {
  id          String    @id @default(cuid())
  title       String
  description String?
  category    String    // registration, governance, financial, compliance, operations, programme
  subcategory String?
  fileName    String
  fileSize    Int       @default(0)
  mimeType    String?
  fileUrl     String?
  version     Int       @default(1)
  status      String    @default("active") // active, archived, deleted
  uploadedBy  String?
  expiryDate  DateTime?
  tags        String?   // JSON array
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([status])
}

// ============ BRANCH ============

model Branch {
  id        String   @id @default(cuid())
  name      String
  code      String   @unique // KL, SEL, PEN, JOH
  address   String?
  city      String?
  state     String?
  phone     String?
  email     String?
  headName  String?
  headPhone String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([code])
}

// ============ OPS CONDUCTOR ============

model WorkItem {
  id                String   @id @default(cuid())
  workItemNumber    String   @unique // auto: WI-XXXX
  title             String
  project           String   @default("PUSPA")
  domain            String   // inventory, reports, cases, donors, volunteers, reminders, messaging, dashboard, continuity, approvals, general
  sourceChannel     String   @default("conductor") // conductor, api, webhook, manual
  requestText       String
  intent            String   // inventory_lookup, report_list, case_query, donor_summary, volunteer_list, reminder_create, work_resume, dashboard_generate, message_reply, general
  status            String   @default("queued") // queued, in_progress, waiting_user, scheduled, blocked, completed, failed, archived
  priority          String   @default("normal") // urgent, high, normal, low
  currentStep       String?
  nextAction        String?
  blockerReason     String?
  resolutionSummary String?
  tags              String?  // JSON array
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  startedAt         DateTime?
  completedAt       DateTime?

  executionEvents ExecutionEvent[]
  artifacts       Artifact[]
  automationJobs  AutomationJob[]

  @@index([status])
  @@index([domain])
  @@index([intent])
  @@index([createdAt])
}

model ExecutionEvent {
  id          String   @id @default(cuid())
  workItemId  String
  workItem    WorkItem @relation(fields: [workItemId], references: [id], onDelete: Cascade)
  type        String   // intent_routed, tool_called, tool_completed, etc.
  summary     String
  detail      String?
  toolName    String?
  status      String   @default("success") // success, failed, pending, skipped
  latencyMs   Int?
  errorCode   String?
  createdAt   DateTime @default(now())

  @@index([workItemId])
  @@index([type])
  @@index([createdAt])
}

model Artifact {
  id          String   @id @default(cuid())
  workItemId  String?
  workItem    WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  type        String   // report, dashboard, summary, export, draft_reply, reminder, snapshot
  title       String
  summary     String?
  pathOrRef   String?
  metadata    String?  // JSON
  createdAt   DateTime @default(now())

  @@index([workItemId])
  @@index([type])
}

model AutomationJob {
  id              String    @id @default(cuid())
  title           String
  description     String?
  kind            String    @default("one_time") // one_time, fixed_rate, cron
  expr            String?
  tz              String    @default("Asia/Kuala_Lumpur")
  domain          String    @default("general")
  relatedProject  String    @default("PUSPA")
  workItemId      String?
  workItem        WorkItem? @relation(fields: [workItemId], references: [id], onDelete: SetNull)
  isEnabled       Boolean   @default(true)
  lastRunAt       DateTime?
  nextRunAt       DateTime?
  lastResult      String?
  failureState    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([isEnabled])
  @@index([nextRunAt])
}

// ============ FASA 1: TRIAGE ENGINE ============

model TriageResult {
  id                String   @id @default(cuid())
  caseId            String   @unique
  priority          String   @default("P3") // P1, P2, P3, P4, P5
  score             Int      @default(0)
  reason            String?
  suggestedProgramme String?
  autoAssigned      Boolean  @default(false)
  assignedVolunteerId String?
  triagedBy         String   @default("ai-agent") // ai-agent, manual
  triagedAt         DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([priority])
  @@index([caseId])
}

// ============ FASA 1: ENHANCED NOTIFICATIONS ============

model NotificationLog {
  id          String   @id @default(cuid())
  type        String   // case.created, donation.received, disbursement.approved, programme.reminder, ekyc.pending, compliance.overdue
  channel     String   @default("in-app") // in-app, whatsapp, telegram, email, sms
  recipient   String   // phone, email, chatId, userId
  title       String
  message     String
  priority    String   @default("medium") // low, medium, high, urgent
  status      String   @default("pending") // pending, sent, delivered, failed
  data        String?  // JSON
  sentAt      DateTime?
  failedReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([createdAt])
}

model NotificationPreference {
  id        String  @id @default(cuid())
  userId    String  @unique
  channels  String  @default("{}")
  events    String  @default("{}")
  quietStart String? // "22:00"
  quietEnd   String? // "08:00"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ============ FASA 1: MULTI-CHANNEL MESSAGES ============

model ChannelMessage {
  id          String   @id @default(cuid())
  channel     String   // whatsapp, telegram, web, sms
  direction   String   // inbound, outbound
  fromId      String?  // sender identifier
  toId        String?  // recipient identifier
  content     String
  messageType String   @default("text") // text, image, document, location, template
  metadata    String?  // JSON
  agentName   String?  // which agent handled this
  sessionId   String?
  isProcessed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([channel])
  @@index([direction])
  @@index([isProcessed])
  @@index([createdAt])
}

// ============ FASA 2: ONBOARDING ============

model OnboardingSession {
  id            String   @id @default(cuid())
  sessionNumber String   @unique // OB-XXXX
  channel       String   @default("web") // web, whatsapp, telegram
  currentStep   Int      @default(0)
  totalSteps    Int      @default(7)
  data          String   @default("{}") // JSON — collected form data
  status        String   @default("active") // active, completed, abandoned, expired
  memberId      String?  // linked after completion
  phone         String?
  icNumber      String?
  name          String?
  expiresAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([status])
  @@index([channel])
  @@index([sessionNumber])
}

// ============ FASA 2: AUTOMATION RULES ============

model AutomationRule {
  id          String   @id @default(cuid())
  name        String
  description String?
  triggerEvent String  // case.created, case.idle, donation.received, disbursement.approved, volunteer.hours_completed, schedule.daily, schedule.weekly
  condition   String?  // e.g. "idleHours > 48"
  actions     String   // JSON array of actions
  isEnabled   Boolean  @default(true)
  priority    Int      @default(0)
  lastTriggeredAt DateTime?
  triggerCount Int     @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([triggerEvent])
  @@index([isEnabled])
}

// ============ FASA 2: PREDICTIVE ANALYTICS ============

model PredictionData {
  id              String   @id @default(cuid())
  modelType       String   // demand_forecast, distribution_optimizer, fund_projection
  period          String   // "2026-07"
  inputSnapshot   String   // JSON — input data used
  prediction      String   // JSON — prediction output
  confidence      Float    @default(0)
  actualValue     String?  // JSON — actual values (for backtesting)
  accuracy        Float?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([modelType])
  @@index([period])
}

// ============ FASA 3: CLAWHUB SKILLS ============

model InstalledSkill {
  id          String   @id @default(cuid())
  skillId     String   @unique
  name        String
  version     String   @default("1.0.0")
  category    String   // communication, productivity, data, finance, security
  description String?
  author      String?
  permissions String?  // JSON
  config      String?  // JSON — skill-specific config
  isEnabled   Boolean  @default(true)
  installedAt DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isEnabled])
}

// ============ FASA 3: AGENT MEMORY ============

model AgentMemory {
  id          String   @id @default(cuid())
  userId      String
  category    String   // personal, case, programme, donation, preference
  content     String
  source      String   @default("user") // user, system, inference
  confidence  Float    @default(1.0)
  accessCount Int      @default(0)
  lastAccessed DateTime @default(now())
  expiresAt   DateTime? // optional expiry
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([lastAccessed])
}

// ============ FASA 3: MULTI-AGENT CONFIG ============

model AgentConfig {
  id            String   @id @default(cuid())
  name          String   @unique
  displayName   String
  role          String   // kewangan, operasi, compliance, asnaf
  description   String?
  model         String   @default("glm-4")
  channels      String   @default("[]") // JSON array of channels
  skills        String   @default("[]") // JSON array of skill IDs
  systemPrompt  String?
  memoryEnabled Boolean  @default(true)
  maxTokens     Int      @default(4096)
  temperature   Float    @default(0.7)
  isActive      Boolean  @default(true)
  lastActiveAt  DateTime?
  totalSessions Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

// ============ FASA 4: BLOCKCHAIN AUDIT TRAIL ============

model AuditTrail {
  id            String   @id @default(cuid())
  txHash        String   @unique
  txType        String   // donation, disbursement, transfer, refund
  fromEntity    String
  toEntity      String
  amount        Float
  currency      String   @default("MYR")
  fundType      String   // zakat, sadaqah, waqf, infaq, general
  status        String   @default("pending") // pending, confirmed, verified, disputed
  blockNumber   Int?
  metadata      String?  // JSON
  verifiedAt    DateTime?
  verifiedBy    String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([txType])
  @@index([fundType])
  @@index([status])
  @@index([txHash])
}

model SmartContractLog {
  id                String   @id @default(cuid())
  disbursementId    String?
  contractType      String   // auto_release, conditional_approval, kyc_required, fund_sufficient
  conditions        String   // JSON array of conditions
  evaluationResult  String   // JSON — result of evaluation
  canRelease        Boolean  @default(false)
  evaluatedAt       DateTime @default(now())
  evaluatedBy       String   @default("smart-contract-engine")
  createdAt         DateTime @default(now())

  @@index([disbursementId])
  @@index([contractType])
  @@index([canRelease])
}
